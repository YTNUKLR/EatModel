# Copy to .env and fill in. The CLI reads these from the environment.

# Required for real OCR (the LLM parser, the default). The CLI FAILS LOUD if this
# is unset — it never silently downgrades. To exercise the pipeline with no key/
# cost, explicitly run the mock: `npm run process:mock` / `npm run recipes:mock`.
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown):
# EATMODEL_PARSER=llm            # receipts: "llm" or "mock"; mock only via `npm run process:mock`
# EATMODEL_RECIPE_PARSER=llm     # recipes:  "llm" or "mock"; mock only via `npm run recipes:mock`
# EATMODEL_MODEL=claude-opus-4-8 # vision model used by both LLM parsers
# EATMODEL_INBOX=receipts/inbox  # point this at your synced Dropbox/iCloud folder
# EATMODEL_PROCESSED=receipts/processed
# EATMODEL_RECIPE_INBOX=recipes/inbox        # synced folder for recipe photos
# EATMODEL_RECIPE_PROCESSED=recipes/processed
# EATMODEL_DB=data/eatmodel.db   # one shared db for receipts and recipes
